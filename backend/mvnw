#!/usr/bin/env sh
set -eu

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -z "${JAVA_HOME:-}" ] && [ -x /usr/lib/jvm/java-17-openjdk-amd64/bin/java ]; then
  export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
  export PATH="$JAVA_HOME/bin:$PATH"
fi
MAVEN_VERSION="${MAVEN_VERSION:-3.9.9}"
MAVEN_DIR="$BASE_DIR/.mvn/apache-maven-$MAVEN_VERSION"
MAVEN_BIN="$MAVEN_DIR/bin/mvn"
MAVEN_REPO="${MAVEN_REPO:-$BASE_DIR/.mvn/repository}"
MAVEN_TMP="$BASE_DIR/target/tmp"

if [ ! -x "$MAVEN_BIN" ]; then
  mkdir -p "$BASE_DIR/.mvn"
  ARCHIVE="$BASE_DIR/.mvn/apache-maven-$MAVEN_VERSION-bin.tar.gz"
  if [ ! -f "$ARCHIVE" ]; then
    URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.tar.gz"
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$URL" -o "$ARCHIVE"
    elif command -v wget >/dev/null 2>&1; then
      wget -q "$URL" -O "$ARCHIVE"
    else
      echo "curl or wget is required to bootstrap Maven" >&2
      exit 1
    fi
  fi
  tar -xzf "$ARCHIVE" -C "$BASE_DIR/.mvn"
fi

mkdir -p "$MAVEN_REPO" "$MAVEN_TMP"
export MAVEN_OPTS="${MAVEN_OPTS:-} -Djava.io.tmpdir=$MAVEN_TMP -Djansi.tmpdir=$MAVEN_TMP"

exec "$MAVEN_BIN" -Dmaven.repo.local="$MAVEN_REPO" "$@"
