POSTGRES_DB=shiliu
POSTGRES_USER=shiliu
POSTGRES_PASSWORD=shiliu_dev_password
POSTGRES_PORT=15432

BACKEND_PORT=8080
SHILIU_PUBLIC_BASE_URL=http://localhost:8080
# Local development default. For any public tunnel, override with a strong token.
SHILIU_ADMIN_TOKEN=dev-admin-token
SHILIU_AGENT_ALLOWED_PROJECT_ROOTS=/home/chase/GitHub/shiliu-ai-v1

OCR_PORT=9000
OCR_LANG=ch
OCR_MODEL_PROFILE=mobile
OCR_USE_TEXTLINE_ORIENTATION=true
OCR_USE_DOC_ORIENTATION=false
OCR_USE_DOC_UNWARPING=false
OCR_ENABLE_MKLDNN=false
OCR_MAX_FILE_MB=15

SHILIU_LLM_ENABLED=true
SHILIU_LLM_API_BASE_URL=
SHILIU_LLM_API_KEY=
